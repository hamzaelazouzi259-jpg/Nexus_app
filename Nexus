      </div>
      <div style="padding:16px;">
        <div id="mp-title" style="color:#fff;margin-bottom:12px;font-size:15px;">منشوراتي</div>
        <div id="mp-list"></div>
      </div>
    </div>

    <nav class="navbar">
      <button class="nav-btn active" id="nav-home"          onclick="switchTab('home')"><span class="nav-icon">🏠</span><span class="nav-label">الرئيسية</span></button>
      <button class="nav-btn"        id="nav-reels"         onclick="switchTab('reels')"><span class="nav-icon">🎬</span><span class="nav-label">ريلز</span></button>
      <button class="nav-btn"        id="nav-messages"      onclick="switchTab('messages')"><span class="nav-icon">💬</span><span class="nav-label">رسائل</span></button>
      <button class="nav-btn"        id="nav-notifications" onclick="switchTab('notifications')"><span class="nav-icon">🔔</span><span class="nav-label">إشعارات</span><span class="nbadge" id="nbadge"></span></button>
      <button class="nav-btn"        id="nav-profile"       onclick="switchTab('profile')"><span class="nav-icon">👤</span><span class="nav-label">حسابي</span></button>
    </nav>
  </div>
</div>

<!-- POST MODAL -->
<div class="ov" id="post-ov" onclick="if(event.target===this)closeModal()">
  <div class="mb">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;">
      <span style="color:#fff;font-size:17px;font-weight:700;">إنشاء منشور</span>
      <button onclick="closeModal()" style="background:rgba(255,255,255,0.1);border:none;border-radius:50%;width:30px;height:30px;color:#fff;cursor:pointer;font-size:15px;">✕</button>
    </div>
    <div style="display:flex;gap:8px;margin-bottom:14px;">
      <button class="type-btn active" onclick="setPT('text',this)">📝 نص</button>
      <button class="type-btn"        onclick="setPT('image',this)">🖼️ صورة</button>
      <button class="type-btn"        onclick="setPT('reel',this)">🎬 ريلز</button>
      <button class="type-btn"        onclick="setPT('video_long',this)">🎥 فيديو</button>
    </div>
    <div style="display:flex;gap:10px;margin-bottom:14px;">
      <div id="m-av" style="width:42px;height:42px;border-radius:50%;background:#6C63FF;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:17px;flex-shrink:0;"></div>
      <textarea id="p-ta" class="pta" placeholder="ماذا يدور في ذهنك؟ (الذكاء الاصطناعي سيحسّنه 🤖)"></textarea>
    </div>
    <button class="bpub" id="pub-btn" onclick="publishPost()">نشر الآن ✨</button>
  </div>
</div>

<!-- STORY VIEWER -->
<div class="sv" id="sv" onclick="closeSV()">
  <div style="color:rgba(255,255,255,0.5);font-size:13px;">اضغط للإغلاق</div>
  <div class="svc" id="svc"><span style="font-size:56px;">✨</span><span id="sv-nm" style="color:#fff;font-weight:700;font-size:17px;"></span></div>
</div>

<script>
// ══ STATE ══
let CU=null, CP=null, POSTS=[], NOTIFS=[], localMsgs={}, followSet=new Set(), allProfs={}, activeCID=null, curPT='text';
const COLORS=['#6C63FF','#FF6584','#43C6AC','#F7971E','#A29BFE','#FD79A8'];
const fmtN=n=>n>=1000?(n/1000).toFixed(1)+'K':n;
const nowT=()=>new Date().toLocaleTimeString('ar',{hour:'2-digit',minute:'2-digit'});
const tAgo=ts=>{const d=(Date.now()-new Date(ts))/1000;if(d<60)return'الآن';if(d<3600)return`منذ ${Math.floor(d/60)} دقيقة`;if(d<86400)return`منذ ${Math.floor(d/3600)} ساعة`;return`منذ ${Math.floor(d/86400)} يوم`;};
const pickC=id=>COLORS[parseInt((id||'0').replace(/-/g,'').slice(0,4),16)%COLORS.length];
const profOf=id=>id===CU?.id?CP:(allProfs[id]||{full_name:'مستخدم',username:'user',avatar_color:'#6C63FF'});
const avEl=(id,sz=40)=>{const p=profOf(id);return`<div style="width:${sz}px;height:${sz}px;border-radius:50%;background:${p.avatar_color||pickC(id)};display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:${Math.round(sz*.38)}px;flex-shrink:0;">${(p.full_name||'م')[0]}</div>`;};
const showErr=m=>{const e=document.getElementById('auth-err');e.textContent=m;e.style.display='block';setTimeout(()=>e.style.display='none',4000);};
const showOK=m=>{const e=document.getElementById('auth-ok');e.textContent=m;e.style.display='block';setTimeout(()=>e.style.display='none',4000);};

// ══ INIT ══
window.addEventListener('DOMContentLoaded',async()=>{
  const{data:{session}}=await db.auth.getSession();
  if(session){CU=session.user;await loadCP();hideLd();launchApp();}
  else{hideLd();document.getElementById('login-page').classList.add('active');}
});
const hideLd=()=>document.getElementById('loading-screen').style.display='none';

// ══ AUTH ══
function switchAuth(m){
  document.querySelectorAll('.tab-switch button').forEach((b,i)=>b.classList.toggle('active',(m==='login'&&i===0)||(m==='register'&&i===1)));
  document.getElementById('form-login').classList.toggle('active',m==='login');
  document.getElementById('form-register').classList.toggle('active',m==='register');
}
async function handleLogin(){
  const em=document.getElementById('l-email').value.trim(), pw=document.getElementById('l-pass').value;
  if(!em||!pw){showErr('يرجى إدخال البريد وكلمة المرور');return;}
  const{data,error}=await db.auth.signInWithPassword({email:em,password:pw});
  if(error){showErr('خطأ: '+error.message);return;}
  CU=data.user;await loadCP();document.getElementById('login-page').classList.remove('active');launchApp();
}
async function handleRegister(){
  const nm=document.getElementById('r-name').value.trim(), un=document.getElementById('r-username').value.trim().replace(/\s/g,''), em=document.getElementById('r-email').value.trim(), pw=document.getElementById('r-pass').value;
  if(!nm||!un||!em||!pw){showErr('يرجى ملء جميع الحقول');return;}
  if(pw.length<6){showErr('كلمة المرور يجب أن تكون 6 أحرف على الأقل');return;}
  const{data,error}=await db.auth.signUp({email:em,password:pw});
  if(error){showErr('خطأ: '+error.message);return;}
  CU=data.user;
  const col=COLORS[Math.floor(Math.random()*COLORS.length)];
  await db.from('profiles').insert({id:CU.id,username:un,full_name:nm,bio:'مرحباً بي في نيكسوس!',avatar_color:col,followers_count:0,following_count:0});
  await loadCP();showOK('تم إنشاء الحساب بنجاح 🎉');
  document.getElementById('login-page').classList.remove('active');launchApp();
}
async function logout(){
  await db.auth.signOut();CU=CP=null;POSTS=[];NOTIFS=[];followSet=new Set();allProfs={};localMsgs={};
  document.getElementById('app-page').classList.remove('active');document.getElementById('login-page').classList.add('active');switchTab('home');
}

// ══ LOAD DATA ══
async function loadCP(){const{data}=await db.from('profiles').select('*').eq('id',CU.id).single();CP=data||{id:CU.id,full_name:CU.email?.split('@')[0]||'مستخدم',username:CU.email?.split('@')[0]||'user',bio:'',avatar_color:'#6C63FF',followers_count:0,following_count:0};}
async function loadAllProfs(){const{data}=await db.from('profiles').select('*');(data||[]).forEach(p=>allProfs[p.id]=p);}
async function loadFollows(){const{data}=await db.from('follows').select('following_id').eq('follower_id',CU.id);followSet=new Set((data||[]).map(r=>r.following_id));}
async function loadPosts(){
  const{data}=await db.from('posts').select('*').order('created_at',{ascending:false}).limit(40);
  const{data:lk}=await db.from('likes').select('post_id').eq('user_id',CU?.id||'');
  const ls=new Set((lk||[]).map(l=>l.post_id));
  POSTS=(data||[]).map(p=>({...p,liked:ls.has(p.id)}));
}
async function loadNotifs(){
  const{data}=await db.from('notifications').select('*').eq('user_id',CU.id).order('created_at',{ascending:false}).limit(20);
  NOTIFS=data||[];renderNotifs();updateBadge();
}

// ══ LAUNCH ══
async function launchApp(){
  document.getElementById('app-page').classList.add('active');
  updateMAv();
  await Promise.all([loadAllProfs(),loadFollows(),loadPosts()]);
  renderAll();
}
function updateMAv(){const e=document.getElementById('m-av');if(!e||!CP)return;e.style.background=CP.avatar_color||'#6C63FF';e.textContent=(CP.full_name||'م')[0];}

// ══ TABS ══
function switchTab(n){
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+n).classList.add('active');
  document.getElementById('nav-'+n).classList.add('active');
  if(n==='notifications'){markRead();}
  if(n==='profile'){renderProf();}
  if(n==='messages'){closeChat();renderMsgList();}
}

function renderAll(){renderStories();renderSuggest();renderPosts();renderReels();renderMsgList();renderNotifs();renderProf();updateBadge();}

// ══ STORIES ══
function renderStories(){
  const c=document.getElementById('stories-wrap');
  let h=`<div class="story-item" onclick="openModal()"><div class="story-add">➕</div><span class="sname">قصتي</span></div>`;
  Object.values(allProfs).filter(p=>p.id!==CU?.id).slice(0,6).forEach(p=>{
    h+=`<div class="story-item" onclick="openSV('${p.id}')"><div class="story-ring"><div class="s-inner" style="background:${p.avatar_color||'#6C63FF'}">${(p.full_name||'م')[0]}</div></div><span class="sname">${(p.full_name||'').split(' ')[0]}</span></div>`;
  });
  c.innerHTML=h;
}
function openSV(id){const p=profOf(id);document.getElementById('svc').style.background=`linear-gradient(135deg,${p.avatar_color||'#6C63FF'},#1a1a2e)`;document.getElementById('sv-nm').textContent=p.full_name||'';document.getElementById('sv').classList.add('open');}
function closeSV(){document.getElementById('sv').classList.remove('open');}

// ══ SUGGEST ══
function renderSuggest(){
  const c=document.getElementById('suggest-list');
  const list=Object.values(allProfs).filter(p=>p.id!==CU?.id&&!followSet.has(p.id)).slice(0,4);
  if(!list.length){c.innerHTML='<span style="color:rgba(255,255,255,0.4);font-size:13px;">أنت تتابع الجميع 🎉</span>';return;}
  c.innerHTML=list.map(p=>`<div class="sc"><div class="sav" style="background:${p.avatar_color||'#6C63FF'}">${(p.full_name||'م')[0]}</div><div style="color:#fff;font-size:12px;font-weight:600;text-align:center;">${p.full_name||''}</div><div style="color:rgba(255,255,255,0.4);font-size:11px;">${fmtN(p.followers_count||0)} متابع</div><button class="btn-follow" onclick="toggleFollow('${p.id}')">متابعة</button></div>`).join('');
}
async function toggleFollow(id){
  if(followSet.has(id)){await db.from('follows').delete().eq('follower_id',CU.id).eq('following_id',id);followSet.delete(id);}
  else{await db.from('follows').insert({follower_id:CU.id,following_id:id});followSet.add(id);await db.from('notifications').insert({user_id:id,actor_id:CU.id,action:'تابعك'});}
  renderSuggest();
}

// ══ POSTS ══
function pcHTML(post){
  const p=profOf(post.user_id);
  let med='';
  if(post.post_type==='video_long'||post.post_type==='reel') med=`<div class="pm"><div class="pplay">${post.post_type==='reel'?'🎬':'▶️'}</div><div style="color:rgba(255,255,255,0.7);font-size:12px;">${post.post_type==='reel'?'🎬 ريلز':'🎥 فيديو'}</div><div class="pvw">👁 ${fmtN(post.views_count||0)}</div></div>`;
  else if(post.post_type==='image') med=`<div class="pimg">🖼️</div>`;
  return`<div class="post-card"><div class="ph">${avEl(post.user_id,40)}<div class="pui"><div class="pun">${p.full_name||'مستخدم'}</div><div class="phd">@${p.username||'user'} · ${tAgo(post.created_at)}</div></div><span style="color:rgba(255,255,255,0.3);font-size:18px;">⋯</span></div>${med}<div class="pt">${post.content}</div><div class="pa"><button class="abt" onclick="toggleLike('${post.id}')"><span style="font-size:17px;">${post.liked?'❤️':'🤍'}</span><span>${post.likes_count>0?fmtN(post.likes_count):''}</span></button><button class="abt"><span style="font-size:17px;">💬</span><span>${post.comments_count>0?fmtN(post.comments_count):''}</span></button><button class="abt"><span style="font-size:17px;">🔁</span></button></div></div>`;
}
function renderPosts(){const c=document.getElementById('posts-list');c.innerHTML=POSTS.length?POSTS.map(pcHTML).join(''):'<div class="empty">لا توجد منشورات بعد. كن أول من ينشر! 🚀</div>';}
async function toggleLike(id){
  const post=POSTS.find(p=>p.id===id);if(!post)return;
  if(post.liked){await db.from('likes').delete().eq('user_id',CU.id).eq('post_id',id);post.liked=false;post.likes_count=Math.max(0,(post.likes_count||1)-1);}
  else{await db.from('likes').insert({user_id:CU.id,post_id:id});post.liked=true;post.likes_count=(post.likes_count||0)+1;if(post.user_id!==CU.id)await db.from('notifications').insert({user_id:post.user_id,actor_id:CU.id,action:'أعجب بمنشورك'});}
  await db.from('posts').update({likes_count:post.likes_count}).eq('id',id);
  renderPosts();renderMyPosts();
}

// ══ REELS ══
function renderReels(){
  const r=POSTS.filter(p=>p.post_type==='reel'||p.post_type==='video_long');
  const c=document.getElementById('reels-grid');
  if(!r.length){c.innerHTML='<div class="empty" style="grid-column:span 2;">لا توجد فيديوهات بعد</div>';return;}
  c.innerHTML=r.map(post=>{const p=profOf(post.user_id);return`<div class="rc"><div class="rt"><span style="font-size:30px;">${post.post_type==='reel'?'🎬':'🎥'}</span></div><div class="ri"><div style="color:rgba(255,255,255,0.8);font-size:12px;margin-bottom:5px;line-height:1.4;">${post.content.slice(0,48)}...</div><div style="color:rgba(255,255,255,0.4);font-size:11px;">❤️ ${fmtN(post.likes_count||0)} · ${p.full_name||''}</div></div></div>`;}).join('');
}

// ══ MESSAGES ══
function renderMsgList(){
  const c=document.getElementById('msg-list');
  const users=Object.values(allProfs).filter(p=>p.id!==CU?.id);
  if(!users.length){c.innerHTML='<div class="empty">لا يوجد مستخدمون آخرون بعد</div>';return;}
  c.innerHTML=users.map(p=>{const ms=localMsgs[p.id]||[];const last=ms[ms.length-1];return`<div class="mi" onclick="openChat('${p.id}')"><div class="maw"><div class="mav" style="background:${p.avatar_color||'#6C63FF'}">${(p.full_name||'م')[0]}</div><div class="odot"></div></div><div style="flex:1;"><div style="display:flex;justify-content:space-between;margin-bottom:2px;"><span style="color:#fff;font-weight:700;">${p.full_name||''}</span><span style="color:rgba(255,255,255,0.3);font-size:12px;">${last?.time||''}</span></div><div style="color:rgba(255,255,255,0.45);font-size:13px;">${last?.text?.slice(0,35)||'ابدأ محادثة...'}</div></div></div>`;}).join('');
}
function openChat(id){
  activeCID=id;const p=profOf(id);
  document.getElementById('msg-list-view').style.display='none';
  document.getElementById('chat-view').classList.add('open');
  const ca=document.getElementById('chat-av');ca.style.background=p.avatar_color||'#6C63FF';ca.textContent=(p.full_name||'م')[0];
  document.getElementById('chat-nm').textContent=p.full_name||'';
  renderChatMsgs();
}
function closeChat(){activeCID=null;document.getElementById('msg-list-view').style.display='block';document.getElementById('chat-view').classList.remove('open');}
function renderChatMsgs(){
  const ms=localMsgs[activeCID]||[];
  const c=document.getElementById('chat-msgs');
  c.innerHTML=ms.map(m=>`<div class="${m.from==='me'?'bwm':'bwt'}"><div class="bbl ${m.from==='me'?'bme':'bth'}"><div style="color:#fff;font-size:14px;">${m.text}</div><div style="color:rgba(255,255,255,0.4);font-size:11px;margin-top:4px;">${m.time}</div></div></div>`).join('');
  c.scrollTop=c.scrollHeight;
}
async function sendMsg(){
  const inp=document.getElementById('chat-inp'),text=inp.value.trim();
  if(!text||!activeCID)return;
  if(!localMsgs[activeCID])localMsgs[activeCID]=[];
  localMsgs[activeCID].push({from:'me',text,time:nowT()});
  inp.value='';renderChatMsgs();renderMsgList();
  const c=document.getElementById('chat-msgs'),t=document.createElement('div');
  t.className='bwt';t.innerHTML='<div class="bbl bth" style="color:rgba(255,255,255,0.5);">يكتب...</div>';c.appendChild(t);c.scrollTop=c.scrollHeight;
  try{
    const p=profOf(activeCID);
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content:`أنت ${p.full_name||'صديق'}، رد بشكل طبيعي وودود باللغة العربية في جملتين فقط: "${text}"`}]})});
    const data=await res.json();t.remove();
    localMsgs[activeCID].push({from:'them',text:data.content?.[0]?.text||'😊',time:nowT()});
    renderChatMsgs();renderMsgList();
  }catch{t.remove();}
}

// ══ NOTIFS ══
function renderNotifs(){
  const c=document.getElementById('notif-list');
  if(!NOTIFS.length){c.innerHTML='<div class="empty">لا توجد إشعارات بعد</div>';return;}
  c.innerHTML=NOTIFS.map(n=>{const p=profOf(n.actor_id);return`<div class="ni${n.is_read?'':' unr'}"><div class="nav2" style="background:${p.avatar_color||'#6C63FF'}">${(p.full_name||'م')[0]}</div><div style="flex:1;"><span style="color:#fff;font-weight:700;">${p.full_name||''}</span> <span style="color:rgba(255,255,255,0.7);">${n.action}</span><div style="color:rgba(255,255,255,0.35);font-size:12px;margin-top:3px;">${tAgo(n.created_at)}</div></div>${n.is_read?'':'<div class="udot"></div>'}</div>`;}).join('');
}
async function markRead(){await db.from('notifications').update({is_read:true}).eq('user_id',CU.id).eq('is_read',false);NOTIFS.forEach(n=>n.is_read=true);renderNotifs();updateBadge();}
function updateBadge(){const u=NOTIFS.filter(n=>!n.is_read).length;const b=document.getElementById('nbadge');b.textContent=u||'';b.style.display=u?'block':'none';}

// ══ PROFILE ══
function renderProf(){
  if(!CP)return;
  const mp=POSTS.filter(p=>p.user_id===CU?.id);
  document.getElementById('pbav').textContent=(CP.full_name||'م')[0];
  document.getElementById('pbav').style.background=CP.avatar_color||'#6C63FF';
  document.getElementById('p-name').textContent=CP.full_name||'';
  document.getElementById('p-handle').textContent='@'+(CP.username||'');
  document.getElementById('p-bio').textContent=CP.bio||'';
  document.getElementById('sp').textContent=mp.length;
  document.getElementById('sf').textContent=CP.followers_count||0;
  document.getElementById('sg').textContent=followSet.size;
  document.getElementById('mp-title').textContent=`منشوراتي (${mp.length})`;
  renderMyPosts();loadNotifs();
}
function renderMyPosts(){const mp=POSTS.filter(p=>p.user_id===CU?.id);const c=document.getElementById('mp-list');c.innerHTML=mp.length?mp.map(pcHTML).join(''):'<div class="empty">لم تنشر شيئاً بعد<br/><button class="btn-pnow" onclick="openModal()">أنشر الآن 🚀</button></div>';}
function toggleEdit(s){document.getElementById('p-view').style.display=s?'none':'block';document.getElementById('p-edit').style.display=s?'block':'none';if(s){document.getElementById('e-name').value=CP.full_name||'';document.getElementById('e-user').value=CP.username||'';document.getElementById('e-bio').value=CP.bio||'';}}
async function saveProf(){
  const nm=document.getElementById('e-name').value.trim(),un=document.getElementById('e-user').value.trim(),bio=document.getElementById('e-bio').value.trim();
  const{error}=await db.from('profiles').update({full_name:nm,username:un,bio}).eq('id',CU.id);
  if(error){alert('خطأ: '+error.message);return;}
  CP={...CP,full_name:nm,username:un,bio};allProfs[CU.id]=CP;
  toggleEdit(false);renderProf();updateMAv();
}

// ══ POST MODAL ══
function openModal(){document.getElementById('post-ov').classList.add('open');document.getElementById('p-ta').focus();}
function closeModal(){document.getElementById('post-ov').classList.remove('open');document.getElementById('p-ta').value='';}
function setPT(t,btn){curPT=t;document.querySelectorAll('.type-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');}
async function publishPost(){
  const text=document.getElementById('p-ta').value.trim();if(!text)return;
  const btn=document.getElementById('pub-btn');btn.disabled=true;btn.textContent='🤖 يحسّن المنشور...';
  let enhanced=text;
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content:`أنت مساعد لشبكة اجتماعية. المستخدم نشر: "${text}". رد بـ JSON فقط بدون backticks: {"enhanced":"نسخة محسّنة مع إيموجي"}`}]})});
    const data=await res.json();
    try{enhanced=JSON.parse(data.content?.[0]?.text||'{}').enhanced||text;}catch{}
  }catch{}
  const{data:np,error}=await db.from('posts').insert({user_id:CU.id,content:enhanced,post_type:curPT,likes_count:0,comments_count:0,views_count:0}).select().single();
  btn.disabled=false;btn.textContent='نشر الآن ✨';
  if(error){alert('خطأ في النشر: '+error.message);return;}
  POSTS.unshift({...np,liked:false});closeModal();renderPosts();renderReels();renderMyPosts();
}
</script>
</body>
</html>
